{
  "name": "devpool-directory-v2",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plan": "npm run build && node dist/cli/plan.js",
    "sync:shard": "npm run build && node dist/cli/sync-shard.js",
    "aggregate": "npm run build && node dist/cli/aggregate.js",
    "summary": "npm run build && node dist/cli/summary.js",
    "backfill": "npm run build && node dist/cli/backfill.js",
    "deduplicate": "npm run build && node dist/cli/dedup.js",
    "bundle": "tsup",
    "bundle:all": "tsup --config tsup.config.ts",
    "twitter:plan": "tsx src/cli/twitter-plan.ts",
    "twitter:apply": "tsx src/cli/twitter-apply.ts",
    "twitter:audit": "tsx src/cli/twitter-audit.ts",
    "test": "vitest",
    "cta:deliver": "npm run build && node dist/cli/cta-delivery.js"
  },
  "dependencies": {
    "@octokit/graphql": "^7.1.1",
    "@octokit/plugin-retry": "^8.0.3",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^20.1.1",
    "dotenv": "^16.4.5",
    "octokit": "^5.0.5",
    "p-limit": "^5.0.0",
    "twitter-api-v2": "^1.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "esbuild": "^0.23.0",
    "tsup": "^8.1.0",
    "tsx": "^3.12.3",
    "typescript": "^5.6.2",
    "vitest": "^4.1.2"
  }
}
